* text=auto eol=crlf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary

# Large Android payloads should use Git LFS only when the project deliberately
# chooses to publish a curated sample APK from source. Normal releases bundle
# generated APK payloads from release assets instead; see docs/lfs-and-assets.md.
*.apk filter=lfs diff=lfs merge=lfs -text
*.aab filter=lfs diff=lfs merge=lfs -text
