{
  "schemaVersion": "rusty.xr.quest-app-catalog.v1",
  "apps": [
    {
      "id": "rusty-xr-quest-composite-layer",
      "label": "Rusty XR Quest Camera Composite Layer",
      "packageName": "com.example.rustyxr.composite",
      "activityName": ".CompositeLayerActivity",
      "apkFile": "apks/rusty-xr-quest-composite-layer-debug.apk",
      "description": "Bundled public Rusty XR immersive Quest example with Camera2 headset-camera composite-layer profiles, a generic diagnostic HUD, OSC listener profiles, native passthrough style hotload profiles, safety-gated strobe profiles, and optional MediaProjection screen streaming."
    }
  ],
  "deviceProfiles": [
    {
      "id": "xr-composite-smoke-test",
      "label": "XR composite smoke test",
      "properties": [
        {
          "key": "debug.oculus.cpuLevel",
          "value": "3"
        },
        {
          "key": "debug.oculus.gpuLevel",
          "value": "3"
        }
      ],
      "description": "Short Quest verification profile for the immersive composite-layer example."
    }
  ],
  "runtimeProfiles": [
    {
      "id": "synthetic-composite-layer",
      "label": "Synthetic layer smoke test",
      "values": {
        "rustyxr.example": "quest-composite-layer-apk",
        "rustyxr.cameraTier": "synthetic",
        "rustyxr.camera": "false",
        "rustyxr.mediaProjection": "false",
        "rustyxr.source": "synthetic",
        "rustyxr.depth": "off"
      },
      "description": "Runs the OpenXR layer without camera or screen capture for lifecycle and renderer isolation."
    },
    {
      "id": "osc-udp-listener",
      "label": "OSC UDP listener",
      "values": {
        "rustyxr.example": "quest-composite-layer-apk",
