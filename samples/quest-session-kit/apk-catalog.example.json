{
  "schemaVersion": "rusty.xr.quest-app-catalog.v1",
  "apps": [
    {
      "id": "rusty-xr-quest-minimal",
      "label": "Rusty XR Minimal Quest APK",
      "packageName": "com.example.rustyxr.minimal",
      "activityName": ".MainActivity",
      "apkFile": "../../../Rusty-XR/examples/quest-minimal-apk/build/outputs/rusty-xr-quest-minimal-debug.apk",
      "description": "Public Rust-native Android smoke-test APK from the sibling Rusty-XR checkout. Build it locally; APK bytes are ignored and not committed."
    },
    {
      "id": "rusty-xr-quest-composite-layer",
      "label": "Rusty XR Quest Camera Composite Layer",
      "packageName": "com.example.rustyxr.composite",
      "activityName": ".CompositeLayerActivity",
      "apkFile": "../../../Rusty-XR/examples/quest-composite-layer-apk/build/outputs/rusty-xr-quest-composite-layer-debug.apk",
      "description": "Public immersive Quest example with explicit synthetic, CPU diagnostic, GPU camera-buffer probe, projected stereo camera tiers, a generic diagnostic HUD, OSC listener profiles, and optional MediaProjection screen streaming."
    },
    {
      "id": "rusty-xr-quest-broker",
      "label": "Rusty XR Quest Broker",
      "packageName": "com.example.rustyxr.broker",
      "activityName": ".MainActivity",
      "apkFile": "../../../Rusty-XR/examples/quest-broker-apk/build/outputs/rusty-xr-quest-broker-debug.apk",
      "description": "Public sidecar broker proof-of-concept APK for localhost WebSocket samples, optional LSL forwarding, optional OSC UDP egress, and OSC-to-WebSocket drive events."
    },
    {
      "id": "example-user-apk",
      "label": "User supplied Quest APK",
      "packageName": "com.example.questapp",
      "activityName": null,
      "apkFile": null,
      "description": "Placeholder target. Replace this metadata or select an APK from the app."
    }
  ],
  "deviceProfiles": [
    {
      "id": "balanced-dev",
      "label": "Balanced development",
      "properties": [
        {
          "key": "debug.oculus.cpuLevel",
          "value": "2"
        },
        {
          "key": "debug.oculus.gpuLevel",
          "value": "2"
        }
      ],
      "description": "Generic development profile for moderate thermal load."
    },
    {
      "id": "perf-smoke-test",
      "label": "Performance smoke test",
      "properties": [
        {
          "key": "debug.oculus.cpuLevel",
          "value": "3"
        },
        {
          "key": "debug.oculus.gpuLevel",
          "value": "3"
        }
      ],
      "description": "Short verification profile for launch and frame-callback checks."
    },
    {
      "id": "xr-composite-smoke-test",
      "label": "XR composite smoke test",
      "properties": [
        {
          "key": "debug.oculus.cpuLevel",
          "value": "3"
        },
        {
          "key": "debug.oculus.gpuLevel",
          "value": "3"
        }
      ],
      "description": "Short Quest verification profile for the immersive composite-layer example."
    },
    {
      "id": "broker-smoke-test",
      "label": "Broker smoke test",
      "properties": [
        {
          "key": "debug.oculus.cpuLevel",
          "value": "2"
        },
        {
          "key": "debug.oculus.gpuLevel",
          "value": "2"
        }
      ],
      "description": "Short Quest verification profile for the non-rendering broker proof-of-concept."
    }
  ],
  "runtimeProfiles": [
    {
      "id": "minimal-contract-log",
      "label": "Minimal contract log",
      "values": {
        "rustyxr.example": "quest-minimal-apk",
        "rustyxr.contracts": "synthetic"
      },
      "description": "Documents that the minimal APK displays synthetic Rusty XR contract JSON and frame callback status."
    },
    {
      "id": "synthetic-composite-layer",
      "label": "Synthetic layer smoke test",
      "values": {
        "rustyxr.example": "quest-composite-layer-apk",
        "rustyxr.cameraTier": "synthetic",
        "rustyxr.camera": "false",
        "rustyxr.mediaProjection": "false",
        "rustyxr.source": "synthetic",
        "rustyxr.depth": "off"
      },
      "description": "Runs the OpenXR layer without camera or screen capture for lifecycle and renderer isolation."
    },
    {
      "id": "osc-udp-listener",
      "label": "OSC UDP listener",
      "values": {
        "rustyxr.example": "quest-composite-layer-apk",
        "rustyxr.cameraTier": "synthetic",
        "rustyxr.camera": "false",
        "rustyxr.mediaProjection": "false",
        "rustyxr.source": "osc-udp",
        "rustyxr.depth": "off",
        "rustyxr.oscEnabled": "true",
        "rustyxr.diagnosticHudVisible": "true",
        "rustyxr.oscListenAddr": "0.0.0.0:9000",
        "rustyxr.oscMaxPacketBytes": "8192"
      },
      "description": "Starts a generic OSC UDP listener in the headset app, draws a headset diagnostics panel inside the camera projection envelope, and logs received packet summaries for companion-to-headset transport checks."
    },
    {
      "id": "osc-udp-listener-no-overlay",
      "label": "OSC UDP listener, no overlay",
      "values": {
        "rustyxr.example": "quest-composite-layer-apk",
        "rustyxr.cameraTier": "synthetic",
        "rustyxr.camera": "false",
        "rustyxr.mediaProjection": "false",
        "rustyxr.source": "osc-udp",
        "rustyxr.depth": "off",
        "rustyxr.oscEnabled": "true",
        "rustyxr.diagnosticHudVisible": "false",
        "rustyxr.oscOverlayEnabled": "false",
        "rustyxr.oscListenAddr": "0.0.0.0:9000",
        "rustyxr.oscMaxPacketBytes": "8192"
      },
      "description": "Starts the same generic OSC UDP listener without drawing the headset diagnostics panel so OSC ingress cost can be measured separately from canvas rendering."
    },
    {
      "id": "broker-latency-websocket-lsl",
      "label": "Broker latency WebSocket to LSL",
      "values": {
        "rustyxr.example": "quest-broker-apk",
        "rustyxr.brokerEndpoint": "ws://127.0.0.1:8765/rustyxr/v1/events",
        "rustyxr.statusEndpoint": "http://127.0.0.1:8765/status",
        "rustyxr.lslStreamName": "rusty_xr_broker_latency",
        "rustyxr.oscEnabled": "false",
        "rustyxr.oscIngressEnabled": "false"
      },
      "description": "Starts the localhost broker endpoint. If a compliant Android liblsl build was supplied at APK build time, latency samples are forwarded as LSL string samples; otherwise they are accepted and logged for API smoke testing."
    },
    {
      "id": "broker-osc-drive-ingress",
      "label": "Broker OSC drive ingress",
      "values": {
        "rustyxr.example": "quest-broker-apk",
        "rustyxr.brokerEndpoint": "ws://127.0.0.1:8765/rustyxr/v1/events",
        "rustyxr.oscEnabled": "false",
        "rustyxr.oscIngressEnabled": "true",
        "rustyxr.oscIngressPort": "9000",
        "rustyxr.oscIngressAddress": "/rusty-xr/drive/radius"
      },
      "description": "Listens for laptop OSC values at /rusty-xr/drive/radius and rebroadcasts accepted values to localhost WebSocket clients as osc_drive JSON events."
