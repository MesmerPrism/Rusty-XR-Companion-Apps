{
  "schemaVersion": "rusty.xr.quest-app-catalog.v1",
  "apps": [
    {
      "id": "rusty-xr-quest-minimal",
      "label": "Rusty XR Minimal Quest APK",
      "packageName": "com.example.rustyxr.minimal",
      "activityName": ".MainActivity",
      "apkFile": "../../../Rusty-XR/examples/quest-minimal-apk/build/outputs/rusty-xr-quest-minimal-debug.apk",
      "description": "Public Rust-native Android smoke-test APK from the sibling Rusty-XR checkout. Build it locally; APK bytes are ignored and not committed."
    },
    {
      "id": "rusty-xr-quest-composite-layer",
      "label": "Rusty XR Quest Camera Composite Layer",
      "packageName": "com.example.rustyxr.composite",
      "activityName": ".CompositeLayerActivity",
      "apkFile": "../../../Rusty-XR/examples/quest-composite-layer-apk/build/outputs/rusty-xr-quest-composite-layer-debug.apk",
      "description": "Public immersive Quest example with explicit synthetic, CPU diagnostic, GPU camera-buffer probe, and projected stereo camera tiers plus optional MediaProjection screen streaming."
    },
    {
      "id": "example-user-apk",
      "label": "User supplied Quest APK",
      "packageName": "com.example.questapp",
      "activityName": null,
      "apkFile": null,
      "description": "Placeholder target. Replace this metadata or select an APK from the app."
    }
  ],
  "deviceProfiles": [
