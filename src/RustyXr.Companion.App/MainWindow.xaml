<Window x:Class="RustyXr.Companion.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="1120"
        Height="760"
        MinWidth="940"
        MinHeight="620"
        Icon="{Binding WindowIconSource}"
        Background="#F7F7F4"
        Foreground="#1E2328">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="0,4,10,10" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#CED4DA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,12,12" />
        </Style>
        <Geometry x:Key="HeaderHeadsetIcon">M2,7 C2,4 3.7,3 6,3 H10 C12.3,3 14,4 14,7 V9 C14,11 12.8,12 11,12 H10 C9.2,12 9.1,10 8,10 C6.9,10 6.8,12 6,12 H5 C3.2,12 2,11 2,9 Z</Geometry>
        <Geometry x:Key="HeaderBatteryIcon">M2,5 H12 V11 H2 Z M12,7 H14 V9 H12</Geometry>
        <Geometry x:Key="HeaderPowerIcon">M8,2 V7 M4.5,4.5 C3.4,5.5 3,6.7 3,8 A5,5 0 1 0 13,8 C13,6.7 12.6,5.5 11.5,4.5</Geometry>
        <Geometry x:Key="HeaderControllerIcon">M2,9 C2,6 4,5 6,6 H10 C12,5 14,6 14,9 L13,11.5 C12.5,12.5 11.2,12.5 10.6,11 L9.7,9.6 H6.3 L5.4,11 C4.8,12.5 3.5,12.5 3,11.5 Z M5,8 H7 M6,7 V9</Geometry>
        <Geometry x:Key="HeaderProximityIcon">M2,8 C3.6,5.5 5.6,4.5 8,4.5 C10.4,4.5 12.4,5.5 14,8 C12.4,10.5 10.4,11.5 8,11.5 C5.6,11.5 3.6,10.5 2,8 Z M8,6.3 A1.7,1.7 0 1 1 8,9.7 A1.7,1.7 0 1 1 8,6.3</Geometry>
        <Geometry x:Key="HeaderAppIcon">M2,3 H14 V13 H2 Z M2,6 H14</Geometry>
        <Geometry x:Key="HeaderRefreshIcon">M13,5 C11.8,3.2 9.6,2.4 7.5,3 C5.4,3.6 4,5.5 4,7.6 M4,3 V7 H8 M3,11 C4.2,12.8 6.4,13.6 8.5,13 C10.6,12.4 12,10.5 12,8.4 M12,13 V9 H8</Geometry>
        <Style x:Key="HeaderStatusChip" TargetType="Border">
            <Setter Property="Background" Value="#252B32" />
            <Setter Property="BorderBrush" Value="#4B5560" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="Margin" Value="0,6,6,0" />
        </Style>
        <Style x:Key="HeaderStatusIcon" TargetType="Path">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Stroke" Value="#AFC1D0" />
            <Setter Property="StrokeThickness" Value="1.6" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="Fill" Value="Transparent" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="HeaderStatusText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DCE5EC" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="HeaderStatusButton" TargetType="Button">
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="Margin" Value="0,6,6,0" />
            <Setter Property="Background" Value="#252B32" />
            <Setter Property="Foreground" Value="#DCE5EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#303741" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HeaderModeToggle" TargetType="ToggleButton">
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="Background" Value="#252B32" />
            <Setter Property="Foreground" Value="#DCE5EC" />
            <Setter Property="BorderBrush" Value="#4B5560" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="BorderBrush" Value="#3DDC84" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#303741" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#20242A" Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       Source="{Binding HeaderIconSource}"
                       Width="52"
                       Height="52"
                       Margin="0,2,14,0"
                       VerticalAlignment="Top" />

                <StackPanel Grid.Column="1" Margin="0,0,18,0">
                    <TextBlock Text="{Binding AppDisplayName}"
                               Foreground="#FFFFFF"
                               FontSize="22"
                               FontWeight="SemiBold"
                               TextWrapping="NoWrap" />
                    <TextBlock Text="Public Windows utility for Quest install, launch, device checks, casting, and diagnostics."
                               Foreground="#D9E2EA"
                               Margin="0,3,0,0" />
                    <TextBlock Foreground="#AFC1D0" Margin="0,3,0,0">
                        <Run Text="{Binding BuildLabel}" />
                        <Run Text=" | " />
                        <Run Text="{Binding UpdateStatus}" />
                    </TextBlock>

                    <WrapPanel Margin="0,1,0,0">
                        <Border Style="{StaticResource HeaderStatusChip}" BorderBrush="{Binding HeaderDeviceStatusColor}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource HeaderHeadsetIcon}" Style="{StaticResource HeaderStatusIcon}" Stroke="{Binding HeaderDeviceStatusColor}" />
                                <TextBlock Text="{Binding HeaderDeviceStatus}" Style="{StaticResource HeaderStatusText}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource HeaderStatusChip}" BorderBrush="{Binding HeaderHeadsetBatteryStatusColor}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource HeaderBatteryIcon}" Style="{StaticResource HeaderStatusIcon}" Stroke="{Binding HeaderHeadsetBatteryStatusColor}" />
                                <TextBlock Text="{Binding HeaderHeadsetBatteryStatus}" Style="{StaticResource HeaderStatusText}" />
                            </StackPanel>
                        </Border>
                        <Button Style="{StaticResource HeaderStatusButton}"
                                BorderBrush="{Binding HeaderPowerStatusColor}"
                                Command="{Binding TogglePowerCommand}"
                                ToolTip="{Binding HeaderPowerActionToolTip}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource HeaderPowerIcon}" Style="{StaticResource HeaderStatusIcon}" Stroke="{Binding HeaderPowerStatusColor}" />
                                <TextBlock Text="{Binding HeaderPowerStatus}" Style="{StaticResource HeaderStatusText}" />
                            </StackPanel>
                        </Button>
                        <Border Style="{StaticResource HeaderStatusChip}" BorderBrush="{Binding HeaderControllerStatusColor}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource HeaderControllerIcon}" Style="{StaticResource HeaderStatusIcon}" Stroke="{Binding HeaderControllerStatusColor}" />
                                <TextBlock Text="{Binding HeaderControllerStatus}" Style="{StaticResource HeaderStatusText}" />
                            </StackPanel>
                        </Border>
                        <Button Style="{StaticResource HeaderStatusButton}"
                                BorderBrush="{Binding HeaderProximityStatusColor}"
                                Command="{Binding ToggleProximityCommand}"
                                ToolTip="{Binding HeaderProximityActionToolTip}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource HeaderProximityIcon}" Style="{StaticResource HeaderStatusIcon}" Stroke="{Binding HeaderProximityStatusColor}" />
                                <TextBlock Text="{Binding HeaderProximityStatus}" Style="{StaticResource HeaderStatusText}" />
                            </StackPanel>
                        </Button>
                        <Border Style="{StaticResource HeaderStatusChip}" BorderBrush="{Binding HeaderForegroundStatusColor}" MaxWidth="440">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource HeaderAppIcon}" Style="{StaticResource HeaderStatusIcon}" Stroke="{Binding HeaderForegroundStatusColor}" />
                                <TextBlock Text="{Binding HeaderForegroundStatus}"
                                           ToolTip="{Binding HeaderForegroundStatus}"
                                           MaxWidth="390"
                                           Style="{StaticResource HeaderStatusText}" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Width="210"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <ToggleButton Content="{Binding SnapshotRefreshModeLabel}"
                                  IsChecked="{Binding SnapshotAutoRefreshEnabled, Mode=TwoWay}"
                                  HorizontalAlignment="Right"
                                  Style="{StaticResource HeaderModeToggle}" />
                    <Button Style="{StaticResource HeaderStatusButton}"
                            BorderBrush="{Binding SnapshotFreshnessColor}"
                            Command="{Binding SnapshotFreshnessCommand}"
                            ToolTip="{Binding SnapshotFreshnessDetail}"
                            HorizontalAlignment="Right"
                            Margin="0,6,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource HeaderRefreshIcon}" Style="{StaticResource HeaderStatusIcon}" Stroke="{Binding SnapshotFreshnessColor}" />
                            <TextBlock Text="Refresh" Style="{StaticResource HeaderStatusText}" />
                        </StackPanel>
                    </Button>
                    <TextBlock Text="Status last refreshed:"
                               Foreground="#AFC1D0"
                               FontSize="11"
                               Margin="0,5,0,0"
                               TextAlignment="Right"
                               TextWrapping="NoWrap" />
                    <TextBlock Text="{Binding SnapshotFreshnessText}"
                               Foreground="{Binding SnapshotFreshnessColor}"
                               FontSize="12"
                               TextAlignment="Right"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Status}"
                               Foreground="#DCE5EC"
                               Margin="0,5,0,0"
                               TextAlignment="Right"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="180" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Column="0" Grid.RowSpan="2">
                <Border Style="{StaticResource PanelBorder}">
                    <StackPanel>
                        <TextBlock Text="Tooling" FontWeight="SemiBold" FontSize="15" />
                        <TextBlock Text="ADB is required. Managed tooling can install official hzdb, Android platform-tools, and scrcpy into LocalAppData." Margin="0,4,0,10" />
                        <Button Content="Refresh Tooling" Command="{Binding RefreshToolsCommand}" />
                        <Button Content="Install / Update Managed Tooling" Command="{Binding InstallToolingCommand}" />
                        <ItemsControl ItemsSource="{Binding Tools}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                        <TextBlock Text="{Binding Detail}" Foreground="#485057" />
                                        <TextBlock Text="{Binding Path}" FontFamily="Consolas" FontSize="11" Foreground="#6B7280" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorder}">
                    <StackPanel>
                        <TextBlock Text="Quest Selector" FontWeight="SemiBold" FontSize="15" />
                        <Button Content="Refresh Devices" Command="{Binding RefreshDevicesCommand}" Margin="0,10,8,8" />
                        <ComboBox ItemsSource="{Binding Devices}"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Serial"
                                  SelectedValue="{Binding SelectedSerial, Mode=TwoWay}"
                                  MinHeight="32"
                                  Margin="0,0,10,10" />
                        <TextBlock Text="Wi-Fi ADB endpoint" />
                        <DockPanel>
                            <TextBox Text="{Binding Endpoint, UpdateSourceTrigger=PropertyChanged}" DockPanel.Dock="Left" Width="190" />
                            <Button Content="Connect" Command="{Binding ConnectCommand}" />
                        </DockPanel>
                        <Button Content="Enable Wi-Fi ADB From USB" Command="{Binding EnableWifiAdbCommand}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <TabControl Grid.Column="1" Grid.Row="0">
                <TabItem Header="Catalog Verify">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="300" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Quest app catalog" FontWeight="SemiBold" />
                            <TextBlock Text="Load public catalog metadata, select the target APK, choose a launch mode, then run the exact action you need." Margin="0,4,0,10" />
                            <Grid Margin="0,0,10,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding CatalogPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,8,0" />
                                <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseCatalogCommand}" />
                                <Button Grid.Column="2" Content="Load" Command="{Binding LoadCatalogCommand}" />
                            </Grid>

                            <TextBlock Text="Catalog app" FontWeight="SemiBold" />
                            <ComboBox ItemsSource="{Binding CatalogApps}"
                                      DisplayMemberPath="Label"
                                      SelectedItem="{Binding SelectedCatalogApp, Mode=TwoWay}"
                                      MinHeight="32"
                                      Margin="0,4,10,10" />

                            <TextBlock Text="Launch mode" FontWeight="SemiBold" />
                            <ComboBox ItemsSource="{Binding RuntimeProfiles}"
                                      SelectedItem="{Binding SelectedRuntimeProfile, Mode=TwoWay}"
                                      MinHeight="42"
                                      MaxDropDownHeight="280"
                                      Margin="0,4,10,8">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,3,0,5" MaxWidth="540">
                                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Description}" Foreground="#485057" FontSize="12" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Text="{Binding SelectedRuntimeProfileDescription}"
                                       Foreground="#485057"
                                       Margin="0,0,10,10" />

                            <WrapPanel>
                                <Button Content="Use In Install / Launch Tab" Command="{Binding UseCatalogAppCommand}" />
                                <Button Content="Install APK Only" Command="{Binding InstallCatalogAppCommand}" />
                                <Button Content="Launch Selected Mode" Command="{Binding LaunchCatalogAppCommand}" />
                                <Button Content="Install + Launch + Verify" Command="{Binding VerifyCatalogAppCommand}" />
                            </WrapPanel>

                            <TextBlock Text="Device profile id" FontWeight="SemiBold" />
                            <TextBox Text="{Binding DeviceProfileId, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Settle time after launch (ms)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding SettleMilliseconds, UpdateSourceTrigger=PropertyChanged}" Width="140" HorizontalAlignment="Left" />
                        </StackPanel>

                        <Border Grid.Column="1" Style="{StaticResource PanelBorder}">
                            <StackPanel>
                                <TextBlock Text="Action Meaning" FontWeight="SemiBold" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="Install APK Only copies the selected APK onto the Quest and does not open it.&#x0a;&#x0a;Launch Selected Mode starts the already-installed app with the selected launch extras.&#x0a;&#x0a;Install + Launch + Verify performs both actions, applies the device profile, waits, and records process, foreground, gfxinfo, and memory signals." />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Device Status">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="320" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" MaxWidth="640" HorizontalAlignment="Left">
                            <TextBlock Text="Headset status" FontWeight="SemiBold" />
                            <TextBlock Text="Latest selected-Quest snapshot: battery, wake state, foreground app, controller batteries, and proximity state." Margin="0,4,0,10" />
                            <TextBlock Text="{Binding LastSnapshot}" FontFamily="Consolas" Margin="0,6,0,16" />

                            <TextBlock Text="Controller batteries" FontWeight="SemiBold" />
                            <ItemsControl ItemsSource="{Binding ControllerStatuses}" Margin="0,6,10,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding HandLabel}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1" Text="{Binding BatteryLabel}" />
                                            <TextBlock Grid.Column="2" Text="{Binding ConnectionStateLabel}" Foreground="#485057" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <Border Grid.Column="1" Style="{StaticResource PanelBorder}">
                            <StackPanel>
                                <TextBlock Text="Proximity Sensor" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding LastProximityStatus}" FontFamily="Consolas" Margin="0,10,0,12" />
                                <TextBlock Text="Keep-awake duration (ms)" />
                                <TextBox Text="{Binding ProximityDurationMs, UpdateSourceTrigger=PropertyChanged}" Width="160" HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Install / Launch">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="280" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="APK" FontWeight="SemiBold" />
                            <DockPanel>
                                <TextBox Text="{Binding ApkPath, UpdateSourceTrigger=PropertyChanged}" DockPanel.Dock="Left" Width="520" />
                                <Button Content="Browse" Command="{Binding BrowseApkCommand}" />
                                <Button Content="Install" Command="{Binding InstallCommand}" />
                            </DockPanel>

                            <TextBlock Text="Target package" FontWeight="SemiBold" />
                            <TextBox Text="{Binding PackageName, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Activity name (optional)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding ActivityName, UpdateSourceTrigger=PropertyChanged}" />

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Launch" Command="{Binding LaunchCommand}" />
                                <Button Content="Stop" Command="{Binding StopCommand}" />
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="1" Style="{StaticResource PanelBorder}">
                            <StackPanel>
                                <TextBlock Text="Last Snapshot" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding LastSnapshot}" FontFamily="Consolas" Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Device Profile">
                    <StackPanel Margin="12" MaxWidth="520" HorizontalAlignment="Left">
                        <TextBlock Text="Quest performance levels" FontWeight="SemiBold" />
                        <TextBlock Text="These development settings are sent through ADB properties. Target apps may expose additional runtime settings through their own catalog files." Margin="0,4,0,12" />
                        <TextBlock Text="CPU level" />
                        <TextBox Text="{Binding CpuLevel, UpdateSourceTrigger=PropertyChanged}" Width="120" HorizontalAlignment="Left" />
                        <TextBlock Text="GPU level" />
                        <TextBox Text="{Binding GpuLevel, UpdateSourceTrigger=PropertyChanged}" Width="120" HorizontalAlignment="Left" />
                        <Button Content="Apply Device Profile" Command="{Binding ApplyProfileCommand}" Width="180" HorizontalAlignment="Left" />
                    </StackPanel>
                </TabItem>

                <TabItem Header="Streams">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="320" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" MaxWidth="620" HorizontalAlignment="Left">
                            <TextBlock Text="Display Cast" FontWeight="SemiBold" />
                            <TextBlock Text="Starts a scrcpy display stream for the selected Quest. Use managed tooling to install scrcpy when it is not already on PATH." Margin="0,4,0,12" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Start Display Cast" Command="{Binding StartCastCommand}" Width="180" />
                                <Button Content="Install / Update Tooling" Command="{Binding InstallToolingCommand}" Width="190" />
                            </StackPanel>

                            <TextBlock Text="MediaProjection Receiver" FontWeight="SemiBold" Margin="0,14,0,0" />
                            <TextBlock Text="Use this with examples that stream display-composite frames over the Rusty XR media-pipeline protocol. Configure adb reverse first, then start the receiver and accept the headset capture prompt." Margin="0,4,0,10" />
                            <TextBlock Text="Receiver port" />
                            <TextBox Text="{Binding MediaPort, UpdateSourceTrigger=PropertyChanged}" Width="120" HorizontalAlignment="Left" />
                            <TextBlock Text="Output folder" />
                            <TextBox Text="{Binding MediaOutputRoot, UpdateSourceTrigger=PropertyChanged}" />
                            <WrapPanel>
                                <Button Content="ADB Reverse Media Port" Command="{Binding ReverseMediaPortCommand}" />
                                <Button Content="Receive One Media Frame" Command="{Binding ReceiveMediaOnceCommand}" />
                            </WrapPanel>

                            <TextBlock Text="Visual Inspection" FontWeight="SemiBold" Margin="0,14,0,0" />
                            <TextBlock Text="Capture a headset screenshot for agent or operator verification. screencap uses ADB first; alternate hzdb methods can be entered when needed." Margin="0,4,0,10" />
                            <TextBlock Text="Screenshot method" />
                            <TextBox Text="{Binding ScreenshotMethod, UpdateSourceTrigger=PropertyChanged}" Width="160" HorizontalAlignment="Left" />
                            <Button Content="Capture Headset Screenshot" Command="{Binding CaptureScreenshotCommand}" Width="230" HorizontalAlignment="Left" />

                        </StackPanel>

                        <Border Grid.Column="1" Style="{StaticResource PanelBorder}">
                            <StackPanel>
                                <TextBlock Text="Last Visual Proof" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding LastVisualProof}" FontFamily="Consolas" Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Diagnostics">
                    <StackPanel Margin="12" MaxWidth="620" HorizontalAlignment="Left">
                        <TextBlock Text="Diagnostics Bundle" FontWeight="SemiBold" />
                        <TextBlock Text="Writes JSON and Markdown diagnostics under LocalAppData so another machine can be debugged without a source checkout." Margin="0,4,0,12" />
                        <Button Content="Write Diagnostics Bundle" Command="{Binding DiagnosticsCommand}" Width="210" HorizontalAlignment="Left" />
                    </StackPanel>
                </TabItem>
            </TabControl>

            <Border Grid.Column="1" Grid.Row="1" Style="{StaticResource PanelBorder}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Operator Log" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ListBox ItemsSource="{Binding Log}" FontFamily="Consolas" FontSize="12" />
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
